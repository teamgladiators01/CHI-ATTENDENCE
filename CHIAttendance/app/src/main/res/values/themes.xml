<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CHIAttendance" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:statusBarColor">@color/primary_green_dark</item>
        <item name="android:navigationBarColor">@color/primary_green_dark</item>
        <item name="actionBarTheme">@style/ActionBarTheme</item>
    </style>

    <style name="Theme.CHIAttendance.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:statusBarColor">@color/primary_green_dark</item>
        <item name="android:navigationBarColor">@color/primary_green_dark</item>
    </style>

    <style name="ActionBarTheme" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:background">@color/primary_green</item>
        <item name="android:titleTextStyle">@style/ActionBarTitleText</item>
    </style>

    <style name="ActionBarTitleText" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="CardStyle">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="DashboardCardStyle" parent="CardStyle">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">6dp</item>
    </style>

    <style name="ButtonPrimary">
        <item name="android:backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="ButtonSecondary">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="strokeColor">@color/primary_green</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="StatCardGreen">
        <item name="cardBackgroundColor">@color/light_green_bg</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
